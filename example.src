struct Point {
    int x;
    int y;
    int arr[10];
};

int fib(int n) {
    if (n == 1) {
        return 1;
    }

    if (n == 2) {
        return 1;
    }

    return fib(n - 1) + fib(n - 2);
}

int fact(int n) {
    if (n == 0) {
        return 1;
    }

    return n * fact(n - 1);
}

int norm(struct Point p) {
    for (int i = 0; i < 5; i++) {
        print_int(p.arr[i]);
    }
    return p.x * p.x + p.y * p.y;
}

struct Point a;
a.x = 5;
a.y = 5;
a.arr[0] = 10101;

print_int(norm(a));