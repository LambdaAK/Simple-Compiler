struct Point {
    int x;
    int y;
    int arr;
};

int fib(int n) {
    if (n == 1) {
        return 1;
    }

    if (n == 2) {
        return 1;
    }

    return fib(n - 1) + fib(n - 2);
}

int fact(int n) {
    if (n == 0) {
        return 1;
    }

    return n * fact(n - 1);
}

int norm(struct Point p) {
    return p.x * p.x + p.y * p.y;
}

struct Point a;
a.x = 5;
a.y = 5;

print_int(norm(a));